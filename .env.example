# Copy this file to .env and fill in real values.
# NEVER commit .env — it is listed in .gitignore.
#
# Owner email for autonomous-run summary drafts (Phase 12 of /seo-blog, Phase 5 of /seo-audit).
# Set this in the routine's cloud environment so the committed workflow files never carry a
# literal personal address. The scheduled agent reads it via `echo "$OWNER_EMAIL"`.
# OWNER_EMAIL=you@example.com

# Example variables for future integrations:
# CONTACT_FORM_API_KEY=your_api_key_here
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# GOOGLE_MAPS_API_KEY=your_google_maps_key
