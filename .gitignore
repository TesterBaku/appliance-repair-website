node_modules/
test/screenshots/

# Playwright output — never commit test run artifacts
test-results/
playwright-report/

# Local task/planning files and run logs — owner's working notes, not part of the site
tasks/
logs/
# Hermes Agent per-run plan scratch (like tasks/) — local working notes, not shared config
.hermes/
*.png
!logo.png
.playwright-mcp/
photo-*.jpeg

# Audit/research screenshots — agents write here; never committed
.audits/

# Staging area for raw photo imports before classification — never committed
.staging/

# Temp images — download trial assets here during tasks; cleaned by `npm run clean:images`
images/temp/*
!images/temp/.gitkeep

# Environment and secrets — never commit these
.env
.env.*
!.env.example

# OS / editor artifacts
.DS_Store
Thumbs.db
*.local
.vscode/

# Claude Code config. The shareable workflow library + rule files are COMMITTED — they are
# the single source of truth for every agent (Claude Code, Codex, Copilot, Hermes; see the
# "Workflow Library" section of AGENTS.md) and must be in the repo so cloud cron runners, which
# clone the default branch, can find them. Only user-local state stays ignored.
.claude/*
!.claude/commands/
!.claude/rules/
!.claude/agents/
!.claude/CLAUDE.md
# still ignored (not negated above): settings.local.json, worktrees/, and any local-only files

# Credentials and keys
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets.json
secrets.yaml
secrets.yml
config/secrets.*
