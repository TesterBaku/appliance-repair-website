#!/usr/bin/env sh
. "$(dirname "$0")/_/husky.sh"

while read local_ref local_sha remote_ref remote_sha; do
  if echo "$remote_ref" | grep -qE '^refs/heads/(master|main)$'; then
    echo "ERROR: Direct pushes to master/main are not allowed."
    echo "Open a pull request from a feature branch instead."
    exit 1
  fi
done
