# Paths secretlint should never scan (gitignore syntax). The pre-commit hook
# scopes to staged files, but this also protects any manual `secretlint "**/*"`
# run from the multi-minute whole-tree scan that motivated the hook change.
node_modules
.git
.husky/_
.claude/worktrees
.playwright-mcp
test-results
dist
coverage

# Binary assets never hold text secrets and slow the scan:
*.png
*.jpg
*.jpeg
*.jfif
*.webp
*.ico
*.woff
*.woff2
*.mp4
